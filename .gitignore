# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.ty_cache/

# Virtual environments
.venv/
venv/

# Bundled FFmpeg — fetched by scripts/fetch_ffmpeg.py, never committed
/bin/*
!/bin/.gitkeep

# Test fixtures — generated by a helper, not committed as binaries
/tests/fixtures/*
!/tests/fixtures/.gitkeep

# Packaging output — the build tree and artifacts, never the build inputs.
/build/
/dist/
# PyInstaller writes throwaway specs next to whatever it is told to freeze; ours
# is a committed, hand-written build input.
*.spec
!/packaging/vidsnap.spec

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
